{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "moondash",
  "version": "0.0.1",
  "identifier": "com.tludwig.moondash",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "moondash",
        "width": 800,
        "height": 480,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "args": [
        {
          "name": "fullscreen",
          "description": "Start in fullscreen"
        },
        {
          "name": "app-config",
          "takesValue": true
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "deb",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
